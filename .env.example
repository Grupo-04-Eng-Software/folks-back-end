# Copie para .env e ajuste conforme necessario: cp .env.example .env
# O docker-compose.yml le estas variaveis (todas tem valor padrao).

# Banco de dados
DB_NAME=folksflow
DB_USER=postgres
DB_PASSWORD=root

# Seguranca da aplicacao
JWT_SECRET=senha-braba-demais-no-docker

# Prefixo da imagem buildada localmente (usuario do Docker Hub)
DOCKERHUB_USERNAME=folksflow
