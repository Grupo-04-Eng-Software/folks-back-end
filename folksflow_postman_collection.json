{
	"info": {
		"_postman_id": "folksflow-v1-full-flow",
		"name": "FolksFlow API v1 - Blank DB Flow",
		"description": "Coleção ajustada para banco de dados vazio. Siga a ordem numérica das pastas.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Setup (Dependências Obrigatórias)",
			"item": [
				{
					"name": "Create Initial Address",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"street\": \"Rua da Paz\",\n    \"number\": \"123\",\n    \"city\": \"Toledo\",\n    \"state\": \"PR\",\n    \"zipCode\": \"85900-000\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/addresses", "host": ["{{baseUrl}}"], "path": ["api", "v1", "addresses"] }
					},
					"description": "Crie um endereço primeiro para obter o address_id (Obrigatório para User)."
				},
				{
					"name": "Create Initial Priority",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Alta\",\n    \"level\": 1\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/priorities", "host": ["{{baseUrl}}"], "path": ["api", "v1", "priorities"] }
					},
					"description": "Crie prioridades (Ex: Baixa, Média, Alta) antes de criar Tasks."
				}
			]
		},
		{
			"name": "2. Auth & User",
			"item": [
				{
					"name": "Register (With Address ID)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Admin User\",\n    \"email\": \"admin@folks.com\",\n    \"password\": \"admin123\",\n    \"addressId\": 1\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "register"] }
					},
					"description": "Certifique-se de passar um addressId válido."
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"accessToken\", jsonData.accessToken);",
									"pm.environment.set(\"refreshToken\", jsonData.refreshToken);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@folks.com\",\n    \"Password\": \"admin123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
					}
				}
			]
		},
		{
			"name": "3. Kanban Workflow",
			"item": [
				{
					"name": "Create Space",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"RH - Matriz\",\n    \"description\": \"Gestão de vagas globais\",\n    \"isActive\": true\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/spaces", "host": ["{{baseUrl}}"], "path": ["api", "v1", "spaces"] }
					}
				},
				{
					"name": "Create Project",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Vaga Dev Java\",\n    \"description\": \"Projeto para recrutamento\",\n    \"spaceId\": 1\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/projects", "host": ["{{baseUrl}}"], "path": ["api", "v1", "projects"] }
					}
				},
				{
					"name": "Create Status (Column)",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"To Do\",\n    \"color\": \"#cccccc\",\n    \"projectId\": 1,\n    \"position\": 0\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/status", "host": ["{{baseUrl}}"], "path": ["api", "v1", "status"] }
					}
				},
				{
					"name": "Create Task (Mandatory Fields)",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Primeira Task\",\n    \"description\": \"Descrição detalhada\",\n    \"statusId\": 1,\n    \"priorityId\": 1,\n    \"position\": 0\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/tasks", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks"] }
					}
				}
			]
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "accessToken", "value": "" },
		{ "key": "refreshToken", "value": "" }
	]
}
