{
	"info": {
		"_postman_id": "folksflow-v1-operational",
		"name": "FolksFlow API v1 - Fluxos Operacionais",
		"description": "Coleção com fluxos reais de uso do Kanban (Movimentação, Atribuição, Colaboração).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "0. Setup & Auth",
			"item": [
				{
					"name": "Login Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"accessToken\", jsonData.accessToken);",
									"pm.environment.set(\"refreshToken\", jsonData.refreshToken);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@folks.com\",\n    \"Password\": \"admin123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
					}
				},
				{
					"name": "Get My Info",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "me"] }
					}
				}
			]
		},
		{
			"name": "1. Gestão de Quadro (Kanban)",
			"item": [
				{
					"name": "Criar Colunas Padrão",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Em Andamento\",\n    \"color\": \"#f1c40f\",\n    \"projectId\": 1,\n    \"position\": 1\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/status", "host": ["{{baseUrl}}"], "path": ["api", "v1", "status"] }
					}
				},
				{
					"name": "Listar Board (Colunas)",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/status/project/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "status", "project", "1"] }
					}
				}
			]
		},
		{
			"name": "2. Operações de Tarefas",
			"item": [
				{
					"name": "Mover Tarefa (Troca de Status)",
					"request": {
						"method": "PATCH",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": {
							"raw": "{{baseUrl}}/api/v1/tasks/1/move?targetStatusId=2&position=0",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "tasks", "1", "move"],
							"query": [
								{ "key": "targetStatusId", "value": "2", "description": "ID da nova coluna" },
								{ "key": "position", "value": "0", "description": "Nova posição na lista (ordenada)" }
							]
						}
					},
					"description": "Simula o 'Drag and Drop' movendo a tarefa de uma coluna para outra."
				},
				{
					"name": "Reordenar Tarefa (Mesma Coluna)",
					"request": {
						"method": "PATCH",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": {
							"raw": "{{baseUrl}}/api/v1/tasks/1/move?targetStatusId=1&position=5",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "tasks", "1", "move"],
							"query": [
								{ "key": "targetStatusId", "value": "1", "description": "Mantém a mesma coluna" },
								{ "key": "position", "value": "5", "description": "Muda apenas a ordem" }
							]
						}
					}
				},
				{
					"name": "Atribuir Responsável",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/tasks/1/assign/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks", "1", "assign", "1"] }
					},
					"description": "Vincula um usuário (userId) à tarefa (taskId)."
				},
				{
					"name": "Remover Responsável",
					"request": {
						"method": "DELETE",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/tasks/1/unassign/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks", "1", "unassign", "1"] }
					}
				}
			]
		},
		{
			"name": "3. Colaboração & Contexto",
			"item": [
				{
					"name": "Adicionar Comentário",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"content\": \"Candidato demonstrou excelente conhecimento em Java 21 na entrevista.\",\n    \"taskId\": 1\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/activities", "host": ["{{baseUrl}}"], "path": ["api", "v1", "activities"] }
					}
				},
				{
					"name": "Criar Tag de Espaço",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Urgente\",\n    \"color\": \"#e74c3c\",\n    \"spaceId\": 1\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/tags", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tags"] }
					}
				},
				{
					"name": "Vincular Tag à Tarefa",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/tags/task/1/associate/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tags", "task", "1", "associate", "1"] }
					}
				}
			]
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "accessToken", "value": "" },
		{ "key": "refreshToken", "value": "" }
	]
}
