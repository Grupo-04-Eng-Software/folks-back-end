{
	"info": {
		"_postman_id": "folksflow-v1-complete",
		"name": "FolksFlow API v1 - COMPLETA",
		"description": "Esta coleção contém TODOS os endpoints do sistema. Organizada para teste do zero ao fluxo real.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Setup & Auth",
			"item": [
				{
					"name": "Create Address",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"street\": \"Rua das Américas\",\n    \"number\": \"500\",\n    \"neighborhood\": \"Centro\",\n    \"city\": \"Toledo\",\n    \"state\": \"PR\",\n    \"country\": \"Brasil\",\n    \"zipCode\": \"85900-000\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/addresses", "host": ["{{baseUrl}}"], "path": ["api", "v1", "addresses"] }
					}
				},
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Novo Usuario\",\n    \"email\": \"user@folks.com\",\n    \"password\": \"user123\",\n    \"addressId\": 1\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "register"] }
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"accessToken\", jsonData.accessToken);",
									"pm.environment.set(\"refreshToken\", jsonData.refreshToken);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@folks.com\",\n    \"Password\": \"admin123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
					}
				},
				{
					"name": "Get My Profile (/me)",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "me"] }
					}
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [],
						"url": { "raw": "{{baseUrl}}/api/v1/auth/refresh?token={{refreshToken}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "refresh"], "query": [ { "key": "token", "value": "{{refreshToken}}" } ] }
					}
				}
			]
		},
		{
			"name": "2. Configurações Globais",
			"item": [
				{
					"name": "List All Priorities",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/priorities", "host": ["{{baseUrl}}"], "path": ["api", "v1", "priorities"] }
					}
				},
				{
					"name": "Create Priority",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Crítica\",\n    \"position\": 4\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/priorities", "host": ["{{baseUrl}}"], "path": ["api", "v1", "priorities"] }
					}
				}
			]
		},
		{
			"name": "3. Espaços & Projetos",
			"item": [
				{
					"name": "List My Spaces",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/spaces", "host": ["{{baseUrl}}"], "path": ["api", "v1", "spaces"] }
					}
				},
				{
					"name": "Create Space",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Engenharia\",\n    \"description\": \"Espaço para times de dev\",\n    \"imageUrl\": \"\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/spaces", "host": ["{{baseUrl}}"], "path": ["api", "v1", "spaces"] }
					}
				},
				{
					"name": "List Projects by Space",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/projects/space/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "projects", "space", "1"] }
					}
				},
				{
					"name": "Create Project",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"FolksFlow Backend\",\n    \"description\": \"API Java Spring\",\n    \"spaceId\": 1\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/projects", "host": ["{{baseUrl}}"], "path": ["api", "v1", "projects"] }
					}
				}
			]
		},
		{
			"name": "4. Kanban (Status & Tasks)",
			"item": [
				{
					"name": "List Status by Project",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/status/project/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "status", "project", "1"] }
					}
				},
				{
					"name": "Create Status",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"To Do\",\n    \"color\": \"#34495e\",\n    \"projectId\": 1,\n    \"position\": 0\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/status", "host": ["{{baseUrl}}"], "path": ["api", "v1", "status"] }
					}
				},
				{
					"name": "List Tasks by Status",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/tasks/status/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks", "status", "1"] }
					}
				},
				{
					"name": "List Overdue Tasks",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/tasks/overdue", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks", "overdue"] }
					},
					"description": "Retorna tarefas com data de vencimento passada que não estão em colunas finalizadas."
				},
				{
					"name": "Create Task",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Implementar Swagger\",\n    \"description\": \"Documentar a API v1\",\n    \"statusId\": 1,\n    \"priorityId\": 1,\n    \"position\": 0\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/v1/tasks", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks"] }
					}
				},
				{
					"name": "Move/Reorder Task",
					"request": {
						"method": "PATCH",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/tasks/1/move?targetStatusId=2&position=0", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks", "1", "move"], "query": [ { "key": "targetStatusId", "value": "2" }, { "key": "position", "value": "0" } ] }
					}
				},
				{
					"name": "Assign User to Task",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/tasks/1/assign/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks", "1", "assign", "1"] }
					}
				},
				{
					"name": "Search Tasks (Filters)",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/tasks?statusId=1&priorityId=1&title=Swagger&page=0&size=10", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks"], "query": [ { "key": "statusId", "value": "1" }, { "key": "priorityId", "value": "1" }, { "key": "title", "value": "Swagger" }, { "key": "page", "value": "0" }, { "key": "size", "value": "10" } ] }
					}
				},
				{
					"name": "Add Checklist Item",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"body": { "mode": "raw", "raw": "Finalizar documentação" },
						"url": { "raw": "{{baseUrl}}/api/v1/tasks/1/checklist", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks", "1", "checklist"] }
					}
				},
				{
					"name": "Start Timer",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/tasks/1/time/start", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks", "1", "time", "start"] }
					}
				},
				{
					"name": "Stop Timer",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
						"url": { "raw": "{{baseUrl}}/api/v1/tasks/1/time/stop", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tasks", "1", "time", "stop"] }
					}
				}
			]
		},
